# ─── Paige environment ───────────────────────────────────────────────
# Copy to .env.local and fill in. Never commit real keys (.env* is gitignored).

# LiveKit — room + voice transport (STT/TTS pipeline, agent participant)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
NEXT_PUBLIC_LIVEKIT_URL=

# Deepgram — streaming speech-to-text for the Paige agent (wake-word "Paige")
DEEPGRAM_API_KEY=

# Moss — semantic retrieval index (the foundation: ingest + query)
MOSS_PROJECT_ID=
MOSS_PROJECT_KEY=
MOSS_INDEX=paige-docs

# Unsiloed — PDF parsing (ingest-time + the one live-upload demo)
UNSILOED_API_KEY=

# TrueFoundry — AI gateway / fallback in front of the LLM + image models
TRUEFOUNDRY_API_KEY=
TRUEFOUNDRY_BASE_URL=
TRUEFOUNDRY_MODEL=

# Image generation race (winner displayed, labeled by model)
MINIMAX_API_KEY=
QWEN_API_KEY=
